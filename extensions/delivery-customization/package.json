{
  "name": "courtyard-delivery-customization",
  "version": "0.0.1",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "build": "shopify app function build",
    "preview": "shopify app function run",
    "test": "vitest run",
    "typegen": "shopify app function typegen"
  },
  "codegen": {
    "schema": "schema.graphql",
    "documents": "src/*.graphql",
    "generates": {
      "./generated/api.ts": {
        "plugins": [
          "typescript",
          "typescript-operations"
        ]
      }
    },
    "config": {
      "omitOperationSuffix": true
    }
  },
  "dependencies": {
    "@shopify/shopify_function": "^2.0.1"
  },
  "devDependencies": {
    "vitest": "^0.29.8"
  }
}
