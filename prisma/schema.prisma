// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model PincodeImportBatch {
  id                 String          @id @default(cuid())
  filename           String
  status             String          @default("previewed")
  totalRows          Int             @default(0)
  validRows          Int             @default(0)
  invalidRows        Int             @default(0)
  duplicateRows      Int             @default(0)
  missingHeadersJson String          @default("[]")
  extraHeadersJson   String          @default("[]")
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  approvedAt         DateTime?
  records            PincodeRecord[]
  publishedSnapshots PublishedConfigSnapshot[]
}

model PincodeRecord {
  id                      String             @id @default(cuid())
  batchId                 String
  batch                   PincodeImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  rowNumber               Int
  rowStatus               String
  rowErrorsJson           String             @default("[]")
  isActive                Boolean            @default(false)
  state                   String             @default("")
  district                String             @default("")
  pincode                 String             @default("")
  locationName            String             @default("")
  areaGroup               String             @default("")
  deliveryAvailability    String             @default("")
  sameDayDeliveryRule     String             @default("")
  nextDayDeliveryRule     String             @default("")
  productAvailabilityRule String             @default("")
  remarks                 String             @default("")
  chargesPricingText      String             @default("")
  updatedSameDayRule      String             @default("")
  updatedNextDayRule      String             @default("")
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  @@index([batchId])
  @@index([isActive])
  @@index([pincode])
}

model PublishedConfigSnapshot {
  id               String              @id @default(cuid())
  schemaVersion    Int
  status           String
  shop             String
  metafieldId      String              @default("")
  sourceBatchId    String?
  sourceBatch      PincodeImportBatch? @relation(fields: [sourceBatchId], references: [id], onDelete: SetNull)
  sourceFilename   String              @default("")
  recordCount      Int                 @default(0)
  payloadSizeBytes Int                 @default(0)
  payloadJson      String
  message          String              @default("")
  publishedAt      DateTime?
  createdAt        DateTime            @default(now())

  @@index([status])
  @@index([shop])
  @@index([sourceBatchId])
}

model ProductRestrictionRule {
  id                       String   @id @default(cuid())
  name                     String
  enabled                  Boolean  @default(true)
  priority                 Int      @default(100)
  productTagsJson          String   @default("[]")
  pincodesJson             String   @default("[]")
  areaGroupsJson           String   @default("[]")
  deliveryAvailabilityText String   @default("")
  validationMessage        String   @default("")
  conditionsJson           String   @default("{}")
  notes                    String   @default("")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([enabled])
  @@index([priority])
}

model ShippingMethodMapping {
  id         String   @id @default(cuid())
  name       String
  enabled    Boolean  @default(true)
  priority   Int      @default(100)
  matchType  String   @default("exact")
  matchValue String   @default("")
  notes      String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([enabled])
  @@index([priority])
}

model PaymentMethodMapping {
  id         String   @id @default(cuid())
  name       String
  enabled    Boolean  @default(true)
  priority   Int      @default(100)
  matchType  String   @default("exact")
  matchValue String   @default("")
  notes      String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([enabled])
  @@index([priority])
}

model CutoffRuleSetting {
  id         String   @id @default(cuid())
  name       String
  enabled    Boolean  @default(true)
  priority   Int      @default(100)
  timeValue  String   @default("")
  timezone   String   @default("")
  matchMode  String   @default("before")
  notes      String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([enabled])
  @@index([priority])
}

model ShippingHideRule {
  id                       String   @id @default(cuid())
  name                     String
  enabled                  Boolean  @default(true)
  priority                 Int      @default(100)
  shippingMethodMappingId  String   @default("")
  cutoffRuleSettingId      String   @default("")
  productTagsJson          String   @default("[]")
  pincodesJson             String   @default("[]")
  areaGroupsJson           String   @default("[]")
  deliveryAvailabilityText String   @default("")
  conditionsJson           String   @default("{}")
  notes                    String   @default("")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([enabled])
  @@index([priority])
  @@index([shippingMethodMappingId])
}

model ShippingRenameRule {
  id                       String   @id @default(cuid())
  name                     String
  enabled                  Boolean  @default(true)
  priority                 Int      @default(100)
  shippingMethodMappingId  String   @default("")
  cutoffRuleSettingId      String   @default("")
  newLabel                 String   @default("")
  productTagsJson          String   @default("[]")
  pincodesJson             String   @default("[]")
  areaGroupsJson           String   @default("[]")
  deliveryAvailabilityText String   @default("")
  conditionsJson           String   @default("{}")
  notes                    String   @default("")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([enabled])
  @@index([priority])
  @@index([shippingMethodMappingId])
}

model PaymentHideRule {
  id                       String   @id @default(cuid())
  name                     String
  enabled                  Boolean  @default(true)
  priority                 Int      @default(100)
  paymentMethodMappingId   String   @default("")
  cutoffRuleSettingId      String   @default("")
  selectedShippingContains String   @default("")
  productTagsJson          String   @default("[]")
  pincodesJson             String   @default("[]")
  areaGroupsJson           String   @default("[]")
  deliveryAvailabilityText String   @default("")
  conditionsJson           String   @default("{}")
  notes                    String   @default("")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([enabled])
  @@index([priority])
  @@index([paymentMethodMappingId])
}
